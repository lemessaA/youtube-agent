# Production Environment Configuration
# Copy this to .env for production deployment

# Groq AI Configuration (Required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024

# Supabase Configuration (Optional - for cloud database)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# YouTube API (Optional - for auto uploads)
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Redis for Celery (Optional - for background tasks)
REDIS_URL=redis://localhost:6379/0

# Production Settings
DEBUG=False
SECRET_KEY=your_secure_secret_key_here

# Storage Configuration
# Options: auto, supabase, file
# auto = try Supabase first, fallback to file storage
# supabase = use Supabase only
# file = use enhanced file storage (recommended for production)
STORAGE_MODE=file

# Security Settings
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Performance Settings
MAX_CONCURRENT_GENERATIONS=3
RATE_LIMIT_PER_MINUTE=100

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO